# Database (matches docker-compose.yml defaults for local dev)
# Prisma CLI reads `.env` in the project root (not `.env.local`). Copy this line to `.env` for `prisma db push` / `db seed`, or duplicate the same URL in `.env.local` for Next.js only.
DATABASE_URL="postgresql://smartcharging:localdev123@localhost:5432/smart_charging?schema=public"

# NextAuth (v5 also reads AUTH_SECRET / AUTH_URL)
AUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# MAX Bot (optional lead notifications)
MAX_BOT_TOKEN="your-max-bot-token"
# Use chat ID for group delivery (preferred for team processing).
MAX_NOTIFY_CHAT_ID="-72895085062802"
# MAX_NOTIFY_USER_ID="71307885"

# Email (Beget SMTP)
SMTP_HOST="smtp.beget.com"
SMTP_PORT="465"
SMTP_USER="info@tts64.ru"
SMTP_PASS="your-email-password"
EMAIL_FROM="ООО Умная зарядка <info@tts64.ru>"

# Analytics — default Metrika ID is in `yandex_metrika.md` / `YANDEX_METRIKA_COUNTER_ID` in constants
# NEXT_PUBLIC_YANDEX_METRIKA_ID="108179739"
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Site
NEXT_PUBLIC_SITE_URL="https://tts64.ru"
NEXT_PUBLIC_COMPANY_PHONE="+79172100660"

# Yandex Maps JS API (contacts page). Optional: without it, an embedded map iframe is used.
# NEXT_PUBLIC_YANDEX_MAPS_API_KEY="your-yandex-maps-api-key"
