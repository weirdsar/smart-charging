# Copy to `.env` or use with docker compose --env-file
# Never commit real secrets.

POSTGRES_USER=smartcharging
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=smart_charging

AUTH_SECRET=<generate-strong-secret>
NEXTAUTH_URL=https://tts64.ru

TELEGRAM_BOT_TOKEN=<bot-token>
TELEGRAM_CHAT_ID=<chat-id>

SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_USER=<email>
SMTP_PASSWORD=<password>
SMTP_FROM=noreply@tts64.ru

NEXT_PUBLIC_SITE_URL=https://tts64.ru
NEXT_PUBLIC_YANDEX_METRIKA_ID=<id>
NEXT_PUBLIC_GA_MEASUREMENT_ID=<id>

# Optional: interactive map on /contacts (otherwise iframe widget without key)
# NEXT_PUBLIC_YANDEX_MAPS_API_KEY=<yandex-maps-api-key>
