// Prisma schema — ООО «Умная зарядка» (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
}

enum CategoryType {
  GENERATORS_PORTABLE
  GENERATORS_INDUSTRIAL
  CHARGING_STATIONS
}

enum FuelType {
  DIESEL
  PETROL
  GAS
  HYBRID
  OTHER
}

enum DocumentType {
  CERTIFICATE
  PERMIT
  GRATITUDE
  OTHER
}

enum LeadType {
  CALLBACK
  COMMERCIAL_OFFER
  LEASING
  QUIZ
  CONTACT
}

enum LeadStatus {
  NEW
  PROCESSED
  CLOSED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([role])
  @@map("users")
}

model Category {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  parentId    String?      @map("parent_id")
  parent      Category?    @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]   @relation("CategoryTree")
  type        CategoryType
  sortOrder   Int          @default(0) @map("sort_order")
  seoTitle    String?      @map("seo_title")
  seoDescription String?   @map("seo_description")
  seoContent  String?      @db.Text @map("seo_content")
  products    Product[]
  filterPages FilterPage[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([type])
  @@map("categories")
}

model Product {
  id               String     @id @default(cuid())
  categoryId       String     @map("category_id")
  category         Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title            String
  slug             String     @unique
  price            Decimal    @db.Decimal(12, 2)
  priceOld         Decimal?   @db.Decimal(12, 2) @map("price_old")
  inStock          Boolean    @default(true) @map("in_stock")
  description      String     @db.Text
  shortDescription String?    @map("short_description")
  specs            Json
  images           String[]   @default([])
  hasAvr           Boolean?   @map("has_avr")
  fuelType         FuelType?
  powerKw          Float?     @map("power_kw")
  noiseLevelDb     Float?     @map("noise_level_db")
  connectorType    String?    @map("connector_type")
  purpose          String?
  seoTitle         String?    @map("seo_title")
  seoDescription   String?    @map("seo_description")
  published        Boolean    @default(false)
  leads            Lead[]
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([published])
  @@map("products")
}

model FilterPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  categoryId      String   @map("category_id")
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  appliedFilters  Json     @map("applied_filters")
  seoTitle        String?  @map("seo_title")
  seoDescription  String?  @map("seo_description")
  seoContent      String?  @db.Text @map("seo_content")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([categoryId])
  @@map("filter_pages")
}

model Project {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  images       String[] @default([])
  task         String   @db.Text
  solution     String   @db.Text
  result       String   @db.Text
  reviewText   String?  @db.Text @map("review_text")
  reviewAuthor String?  @map("review_author")
  published    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([published])
  @@map("projects")
}

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  content        String    @db.Text
  excerpt        String?
  coverImage     String?   @map("cover_image")
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @map("seo_description")
  published      Boolean   @default(false)
  publishedAt    DateTime? @map("published_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([published])
  @@index([publishedAt])
  @@map("blog_posts")
}

model Document {
  id        String       @id @default(cuid())
  title     String
  fileUrl   String       @map("file_url")
  docType   DocumentType @map("doc_type")
  sortOrder Int          @default(0) @map("sort_order")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([docType])
  @@map("documents")
}

model Lead {
  id          String      @id @default(cuid())
  type        LeadType
  name        String
  phone       String
  email       String?
  message     String?     @db.Text
  productId   String?     @map("product_id")
  product     Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  quizData    Json?       @map("quiz_data")
  sourcePage  String      @map("source_page")
  utmData     Json?       @map("utm_data")
  status      LeadStatus  @default(NEW)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([type])
  @@index([status])
  @@index([productId])
  @@map("leads")
}

model Page {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  content        String   @db.Text
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description")
  published      Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([published])
  @@map("pages")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
